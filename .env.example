# Misskey instance URL.
# Used by src/pages/index.astro (the home page) as the readonly
# default for the Misskey streaming section. If unset, the page
# falls back to https://misskey.io and logs a console warning in
# dev. Not exposed to the browser (no PUBLIC_ prefix) — only the
# rendered readonly input value crosses the server/client boundary.
MISSKEY_INSTANCE_URL=https://your-instance.misskey.example

# Misskey API token (generate from your instance settings)
MISSKEY_API_TOKEN=your_token_here

# VoiceVox API URL (server-only; intentionally without the PUBLIC_ prefix so the
# value is not inlined into client bundles if a future import is mis-scoped)
VOICEVOX_URL=http://localhost:50021
