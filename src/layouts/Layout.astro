---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Misskey timeline reader with VoiceVox TTS" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <slot />
  </body>
</html>
