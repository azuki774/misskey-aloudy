---
const navLinks = [
  { href: '/', label: 'Home' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-bg-subtle backdrop-blur border-b border-border sticky top-0 z-10">
  <div class="container mx-auto flex items-center justify-between gap-4 px-4 py-3 sm:py-4">
    <a
      href="/"
      class="text-lg font-semibold tracking-tight text-fg hover:opacity-80 transition-opacity"
    >
      misskey-aloudy
    </a>
    <nav aria-label="メインナビゲーション">
      <ul class="flex items-center gap-2 sm:gap-4 text-sm sm:text-base">
        {
          navLinks.map(({ href, label }) => {
            const isActive =
              href === '/'
                ? currentPath === '/'
                : currentPath === href || currentPath.startsWith(`${href}/`);
            return (
              <li>
                <a
                  href={href}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'inline-block rounded-md px-3 py-1.5 transition-colors',
                    isActive
                      ? 'bg-accent-bg text-accent-fg'
                      : 'text-fg-subtle hover:bg-accent-hover',
                  ]}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>
