---
import Layout from "../layouts/Layout.astro";
import { FALLBACK_INSTANCE_URL, resolveInstanceUrl } from "../lib/instanceUrl.ts";

const instanceUrl = resolveInstanceUrl();
if (process.env.NODE_ENV !== "production" && instanceUrl === FALLBACK_INSTANCE_URL) {
	console.warn(
		`[index] MISSKEY_INSTANCE_URL is not set; falling back to ${FALLBACK_INSTANCE_URL}`,
	);
}
---

<Layout title="misskey-aloudy" description="Misskey のタイムラインを VoiceVox で読み上げる Web アプリ">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold tracking-tight">misskey-aloudy</h1>
    <p class="mt-2 text-fg-muted">
      Misskey インスタンスのグローバルタイムラインを購読し、受信したノートをリアルタイムで表示します。
    </p>
    <p class="mt-2 text-sm text-fg-muted">
      使い方: ページを開くと自動で Misskey に接続します。「接続済み」と表示されたら、下の「読み上げ」スイッチを ON にしてください。以降、届いたノートが自動で読み上げられます。
    </p>

    <div class="mt-6">
      <label for="instance-url" class="block text-sm font-medium">
        Misskey インスタンス
      </label>
      <input
        id="instance-url"
        type="text"
        readonly
        aria-readonly="true"
        aria-label="Misskey instance URL (read-only)"
        value={instanceUrl}
        class="mt-1 w-full rounded-md border border-border bg-bg-subtle p-2 font-mono text-sm shadow-sm"
      />
    </div>

    <div class="mt-4 flex gap-2">
      <button
        id="connect"
        type="button"
        class="rounded-md bg-accent-bg px-4 py-2 text-sm font-medium text-accent-fg transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50"
      >
        接続
      </button>
      <button
        id="disconnect"
        type="button"
        disabled
        class="rounded-md border border-border bg-bg px-4 py-2 text-sm font-medium text-fg transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-50"
      >
        切断
      </button>
      <button
        id="reading-toggle"
        type="button"
        role="switch"
        aria-checked="false"
        disabled
        class="group inline-flex items-center gap-2 rounded-md border border-border bg-bg px-3 py-2 text-sm font-medium text-fg transition-colors hover:bg-accent-hover disabled:cursor-not-allowed disabled:opacity-50 aria-checked:border-green-600 aria-checked:bg-green-50 aria-checked:text-green-700 dark:aria-checked:border-green-400 dark:aria-checked:bg-green-950 dark:aria-checked:text-green-300"
      >
        <span class="relative inline-block h-5 w-9 rounded-full bg-gray-300 transition-colors group-aria-checked:bg-green-500" aria-hidden="true">
          <span class="absolute top-0.5 left-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform group-aria-checked:translate-x-4"></span>
        </span>
        <span>読み上げ</span>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <g id="reading-toggle-icon-off">
            <path d="M11 5L6 9H2v6h4l5 4V5z" />
            <line x1="23" y1="9" x2="17" y2="15" />
            <line x1="17" y1="9" x2="23" y2="15" />
          </g>
          <g id="reading-toggle-icon-on" hidden>
            <path d="M11 5L6 9H2v6h4l5 4V5z" />
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
          </g>
        </svg>
      </button>
    </div>

    <p class="mt-4 text-sm">
      Misskey 接続: <span id="state" class="font-medium">未接続</span>
    </p>
    <p class="mt-1 text-sm">
      読み上げ: <span id="reading-status" class="font-medium">OFF</span>
    </p>
    <p
      id="error"
      class="mt-2 hidden text-sm text-red-600 dark:text-red-400"
      role="alert"
      aria-live="assertive"
    >
    </p>

    <h2 class="mt-8 text-lg font-semibold">
      受信ノート (<span id="count">0</span>)
    </h2>
    <ul
      id="notes"
      class="mt-2 max-h-[60vh] divide-y divide-border overflow-y-auto rounded-md border border-border"
    >
    </ul>
  </main>
</Layout>

<script>
  import "../scripts/index.ts";
</script>
